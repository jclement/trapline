# Trapline Dashboard Configuration
#
# Copy to .env and fill in values.

# Password for the web dashboard login
PASSWORD=change-me-to-something-secure

# Comma-separated publish secrets — one per agent host.
# Generate with: openssl rand -hex 32
# Give each host its own secret so you can revoke individually.
PUBLISH_SECRETS=secret-for-server1,secret-for-server2,secret-for-server3
